# Groq API Key
# Получить: https://console.groq.com/keys
# Быстрый инференс, есть бесплатный тариф

GROQ_API_KEY=your_groq_api_key_here

# Пример: GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google Gemini API Key (альтернатива)
# Получить: https://aistudio.google.com/apikey
# Работает в РФ без VPN, есть бесплатный тариф (15 запросов/мин)

GEMINI_API_KEY=your_gemini_api_key_here

# Пример: GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telegram Bot для уведомлений о входах пользователей
# Создать бота: @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=478799066
