# GigaChat API Credentials (Сбер)
# Получить: https://developers.sber.ru/gigachat

# Вариант 1 (простой): Access Token
# Действует 30 минут, нужно обновлять вручную
# Подходит для тестов
GIGACHAT_ACCESS_TOKEN=your_access_token_here

# Вариант 2 (правильный): Client ID + Client Secret
# Токен получается автоматически, работает постоянно
# Для продакшена используй этот вариант
GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_client_secret

# API Key для текстовых запросов (не требует OAuth)
VITE_GIGACHAT_API_KEY=your_api_key_here
